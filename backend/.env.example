# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/anya-eydman

# ─── Google OAuth2 (Calendar API) ─────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create a project → Enable "Google Calendar API"
# 3. Credentials → Create OAuth 2.0 Client ID (Web application)
# 4. Add http://localhost:5000/api/auth/google/callback to Authorized redirect URIs
# 5. Download the JSON and fill in the values below
GOOGLE_CLIENT_ID=987113855878-9ohu6uncnf31llfdk3r8vgefsguqnnff.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# After running the one-time OAuth flow (GET /api/auth/google), paste the
# refresh token you receive here so the server can create events without
# re-authenticating every restart.
GOOGLE_REFRESH_TOKEN=1//0gzKifWfKtrTyCgYIARAAGBASNwF-L9Irey12f9XuQyJl4mPVJAth2OLwuBhGETaa_AKYLvpWelHMj8PLtQLPABx9Ssi_5vK8NT0

# ─── Calendar Settings ────────────────────────────────────────────────────────
# The Google Calendar ID to create events on. Use "primary" for the main
# calendar of the authenticated account, or paste a specific calendar ID.
GOOGLE_CALENDAR_ID=primary

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000
